# Server
PORT=3000

# OpenAI API Key (for audio transcription via Whisper)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for AI scorecard generation)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend API Key (for email delivery)
RESEND_API_KEY=your_resend_api_key_here

# Email sender address (must be verified in Resend)
EMAIL_FROM=noreply@yourdomain.com

# Minimum AI score (0-100) that triggers a flag/alert email
FLAG_SCORE_THRESHOLD=70
